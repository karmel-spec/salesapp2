# ── Brigham Larson Pianos Sales Console — environment ──────────────
# Copy to .env.local for development. Nothing is required to boot:
# with no vars set, the app runs in read-only snapshot mode against
# the Leads Log share link.

# The Leads Log spreadsheet (defaults to the live BLP Leads Log)
SHEET_ID=1sdOeaChihEjAQBCi8U0_lTTlYP4H38eiC6zgmRLoWC0
# SHEET_TAB=            # blank = first tab, autodetected

# ── Two-way sync (Google service account) ──
# 1. Google Cloud Console → create a project → enable "Google Sheets API"
# 2. Create a service account, generate a JSON key
# 3. Share the Leads Log with the service account email as EDITOR
# 4. Paste the values here (keep the \n escapes in the private key)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# ── Team access ──
# Shared passcode gating the whole console (same model as BLP Mega App).
BLP_APP_ACCESS_KEY=

# ── Twilio SMS (approved text drafts send through this) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=     # E.164, e.g. +18017690054 — Karmel is confirming

# ── Email (approved email drafts send from info@) ──
# Google Workspace → info@brighamlarsonpianos.com → App Passwords
SMTP_USER=info@brighamlarsonpianos.com
SMTP_PASS=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
EMAIL_FROM_NAME=Brigham Larson Pianos

# ── Arnold, Chief Sales Agent (Telegram @arnoldlarsonbot / Hermes) ──
# Hermes gateway endpoint the app pings when you click "Ask Arnold"
ARNOLD_WEBHOOK_URL=
ARNOLD_WEBHOOK_SECRET=      # HMAC shared secret for both directions
BLP_ARNOLD_ACCESS_KEY=      # draft-only key Arnold sends in x-blp-key
# Team notifications from Arnold's bot into your sales group chat
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Claude API fallback (drafts in Arnold's voice when Hermes is down) ──
ANTHROPIC_API_KEY=

# ── Business rules (defaults shown) ──
# STALE_DAYS=30
# DEFAULT_REP=Brigham
# STALE_REP=Arnold
